# ════════════════════════════════════════════════════════
#  AutoApplier — Environment Configuration
#  Copy this file to .env and fill in YOUR values
# ════════════════════════════════════════════════════════

# ── REQUIRED: Free Groq API key → https://console.groq.com ───
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-70b-versatile

# ── REQUIRED: LinkedIn Credentials (real apply ke liye) ───────
LINKEDIN_EMAIL=your_linkedin_email@gmail.com
LINKEDIN_PASSWORD=your_linkedin_password

# ── App Security ──────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-secret-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/autoapplier.db

# ── FastAPI Backend ───────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_URL=http://localhost:8000

# ── Playwright Browser ────────────────────────────────────────
# false = browser screen pe dikhega (recommended for testing)
# true  = background mein chalta hai
PLAYWRIGHT_HEADLESS=false
PLAYWRIGHT_SLOW_MO=100
PLAYWRIGHT_TIMEOUT=40000

# ── Agent Settings ────────────────────────────────────────────
MAX_APPLICATIONS_PER_RUN=50
APPLICATION_DELAY_SECONDS=3
